# Anthropic API 키 (fake 데모에서는 비워둔다)
ANTHROPIC_API_KEY=

# 지식베이스 디렉토리 — 위키 기본팩, 필요하면 다른 폴더로 교체한다
KNOWLEDGE_DIR=knowledge-wiki

# 사용할 모델
# - auto: codex-cli:gpt-5.3-codex-spark -> fake 순서로 시도
# - fake: API 호출 없는 결정론 데모
# - claude-cli: 로컬 Claude CLI
# - codex-cli 또는 codex-cli:gpt-5.3-codex-spark: Codex CLI 실응답
MODEL=codex-cli
CODEX_MODEL=gpt-5.3-codex-spark
# auto 모드 순서. 비워두면 codex-cli:${CODEX_MODEL} -> fake
MODEL_CHAIN=codex-cli:gpt-5.3-codex-spark,fake

# 리버스 프록시 hop 수 (X-Forwarded-For 신뢰 범위, rate limit에 사용)
# 프록시 뒤인데 0으로 두면 IP 스푸핑으로 rate limit이 우회된다. 플랫폼 홉수에
# 정확히 맞춘다. 0인데 XFF 헤더가 관측되면 서버 로그에 1회 경고가 남는다.
TRUST_PROXY_HOPS=0

# 하루 최대 요청 수 캡
DAILY_REQUEST_CAP=500

# 통계 대시보드(/api/stats, static/stats.html) 접근 토큰. 미설정이면 /api/stats는
# 전부 401이다(무인증 전체 덤프 금지). 브라우저 대시보드는 URL에 ?token=<값>을
# 붙여 연다(stats.js가 X-Stats-Token 헤더로 전달). 랜덤 문자열로 설정한다.
STATS_DASHBOARD_TOKEN=
